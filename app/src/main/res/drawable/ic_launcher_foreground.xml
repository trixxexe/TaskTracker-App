<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Subtle Drop Shadow for depth -->
    <path
        android:fillColor="#15000000"
        android:pathData="M 33,31 h 42 c 5,0 9,4 9,9 v 42 c 0,5 -4,9 -9,9 h -42 c -5,0 -9,-4 -9,-9 v -42 c 0,-5 4,-9 9,-9 z" />

    <!-- Sleek Rounded Card Base (The Planner Sheet) -->
    <path
        android:pathData="M 32,30 h 44 c 5,0 9,4 9,9 v 44 c 0,5 -4,9 -9,9 h -44 c -5,0 -9,-4 -9,-9 v -44 c 0,-5 4,-9 9,-9 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="32"
                android:startY="30"
                android:endX="85"
                android:endY="92">
                <item android:color="#1E293B" android:offset="0.0" />
                <item android:color="#0F172A" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- White Border Outline for premium contrast -->
    <path
        android:pathData="M 32,30 h 44 c 5,0 9,4 9,9 v 44 c 0,5 -4,9 -9,9 h -44 c -5,0 -9,-4 -9,-9 v -44 c 0,-5 4,-9 9,-9 z"
        android:strokeColor="#334155"
        android:strokeWidth="1.5" />

    <!-- Custom Modern checklist lines -->
    <!-- Line 1 -->
    <path
        android:pathData="M 46,42 L 72,42"
        android:strokeColor="#64748B"
        android:strokeWidth="3.5"
        android:strokeLineCap="round" />
    <path
        android:pathData="M 36,42 L 38,42"
        android:strokeColor="#F97316"
        android:strokeWidth="3.5"
        android:strokeLineCap="round" />

    <!-- Line 2 -->
    <path
        android:pathData="M 46,54 L 66,54"
        android:strokeColor="#64748B"
        android:strokeWidth="3.5"
        android:strokeLineCap="round" />
    <path
        android:pathData="M 36,54 L 38,54"
        android:strokeColor="#F97316"
        android:strokeWidth="3.5"
        android:strokeLineCap="round" />

    <!-- Line 3 -->
    <path
        android:pathData="M 46,66 L 70,66"
        android:strokeColor="#64748B"
        android:strokeWidth="3.5"
        android:strokeLineCap="round" />
    <path
        android:pathData="M 36,66 L 38,66"
        android:strokeColor="#F97316"
        android:strokeWidth="3.5"
        android:strokeLineCap="round" />

    <!-- Hero Glowing Checkmark overlay representing completion -->
    <path
        android:pathData="M 52,70 L 62,80 L 85,50"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="52"
                android:startY="50"
                android:endX="85"
                android:endY="80">
                <item android:color="#38BDF8" android:offset="0.0" />
                <item android:color="#F43F5E" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
